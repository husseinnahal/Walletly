<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".Addtransactation">

    <TextView
        android:id="@+id/amtraa"
        android:layout_width="135dp"
        android:layout_height="38dp"
        android:layout_marginStart="24dp"
        android:layout_marginTop="28dp"
        android:text="Amount"
        android:textColor="#1A38B3"
        android:textSize="26sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/titletrainput" />

    <Button
        android:id="@+id/backsave"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="19dp"
        android:layout_marginTop="26dp"
        android:backgroundTint="#10D1D1D1"
        android:text="back"
        android:textColor="#000000"
        android:textSize="24sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <RadioGroup
        android:id="@+id/rg_type"
        android:layout_width="363dp"
        android:layout_height="157dp"
        android:layout_marginStart="19dp"
        android:layout_marginTop="26dp"
        android:layout_marginEnd="21dp"
        android:background="@drawable/radius"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/backsave">

        <RadioButton
            android:id="@+id/rb_expenses"
            android:layout_width="match_parent"
            android:layout_height="85dp"
            android:background="#5C9FFE"
            android:text="Expenses"
            android:textAlignment="center"
            android:textColor="#FFFFFF"
            android:textSize="24sp" />

        <RadioButton
            android:id="@+id/rb_income"
            android:layout_width="match_parent"
            android:layout_height="75dp"
            android:background="#5C9FFE"
            android:text="Income"
            android:textAlignment="center"
            android:textColor="#FFFFFF"
            android:textSize="24sp" />

    </RadioGroup>

    <TextView
        android:id="@+id/date"
        android:layout_width="75dp"
        android:layout_height="36dp"
        android:layout_marginStart="24dp"
        android:layout_marginTop="44dp"
        android:text="Title"
        android:textColor="#1A38B3"
        android:textSize="26sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/rg_type" />

    <TextView
        android:id="@+id/cattra"
        android:layout_width="135dp"
        android:layout_height="38dp"
        android:layout_marginStart="24dp"
        android:layout_marginTop="140dp"
        android:text="Category"
        android:textColor="#1A38B3"
        android:textSize="26sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/titletrainput" />

    <EditText
        android:id="@+id/titletrainput"
        android:layout_width="340dp"
        android:layout_height="43dp"
        android:layout_marginStart="25dp"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="46dp"
        android:background="@drawable/edittext_border"
        android:inputType="text"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/date" />

    <EditText
        android:id="@+id/savedamunt"
        android:layout_width="340dp"
        android:layout_height="43dp"
        android:layout_marginStart="25dp"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="46dp"
        android:background="@drawable/edittext_border"
        android:inputType="number"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/amtraa" />

    <EditText
        android:id="@+id/cattraninput"
        android:layout_width="340dp"
        android:layout_height="43dp"
        android:layout_marginStart="25dp"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="46dp"
        android:background="@drawable/edittext_border"
        android:inputType="text"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/cattra" />

    <Button
        android:id="@+id/createam"
        android:layout_width="340dp"
        android:layout_height="57dp"
        android:layout_marginStart="25dp"
        android:layout_marginTop="28dp"
        android:layout_marginEnd="46dp"
        android:background="@drawable/radius"
        android:backgroundTint="#152156"
        android:text="create"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/cattraninput" />


</androidx.constraintlayout.widget.ConstraintLayout>